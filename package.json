{
    "name": "@legendaryvibecoder/gigabrain",
    "version": "0.7.1",
    "type": "module",
    "description": "Local-first memory control plane for agents — cross-host recall, provenance, dedupe, audit, native sync",
    "author": "Legendary Vibecoder",
    "homepage": "https://github.com/legendaryvibecoder/gigabrain#readme",
    "bugs": {
        "url": "https://github.com/legendaryvibecoder/gigabrain/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/legendaryvibecoder/gigabrain.git"
    },
    "engines": {
        "node": ">=22"
    },
    "license": "MIT",
    "scripts": {
        "setup": "node scripts/setup-first-run.js",
        "codex:setup": "node scripts/gigabrain-codex-setup.js",
        "hermes:setup": "node scripts/gigabrain-hermes-setup.js",
        "codex:mcp": "node scripts/gigabrain-mcp.js",
        "codex:checkpoint": "node scripts/gigabrain-codex-checkpoint.js --config \"$HOME/.gigabrain/config.json\" --surface codex",
        "codex:doctor": "node scripts/gigabrainctl.js doctor --config \"$HOME/.gigabrain/config.json\" --target both",
        "codex:maintain": "node scripts/gigabrainctl.js maintain --config \"$HOME/.gigabrain/config.json\"",
        "claude:setup": "node scripts/gigabrain-claude-setup.js",
        "claude:checkpoint": "node scripts/gigabrain-codex-checkpoint.js --config \"$HOME/.gigabrain/config.json\" --surface claude",
        "claude:doctor": "node scripts/gigabrainctl.js doctor --config \"$HOME/.gigabrain/config.json\" --target both",
        "claude:maintain": "node scripts/gigabrainctl.js maintain --config \"$HOME/.gigabrain/config.json\"",
        "claude:desktop:bundle": "node scripts/build-claude-desktop-bundle.js",
        "claude:desktop:bundle:release": "node scripts/build-claude-desktop-bundle.js --portable",
        "eval:deep-recall": "node eval/run-deep-recall-eval.js",
        "test": "node tests/run-all.js",
        "test:unit": "node tests/run-all.js --filter unit",
        "test:integration": "node tests/run-all.js --filter integration",
        "test:regression": "node tests/run-all.js --filter regression",
        "test:performance": "node tests/run-all.js --filter performance",
        "test:release-live": "RELEASE_LIVE_SMOKE=1 node tests/release-live-codex-cli-test.js && RELEASE_LIVE_SMOKE=1 node tests/release-live-openclaw-install-test.js",
        "test:release": "node tests/run-all.js && npm run audit:high && npm run pack:dry-run && npm run test:release-live && npm run eval:deep-recall",
        "demo:passport": "scripts/demo-memory-passport.sh",
        "audit:high": "npm audit --audit-level=high",
        "pack:dry-run": "npm --cache \"${TMPDIR:-/tmp}/gigabrain-npm-cache\" pack --dry-run",
        "gigabrainctl": "node scripts/gigabrainctl.js",
        "nightly": "node scripts/gigabrainctl.js nightly",
        "maintain": "node scripts/gigabrainctl.js maintain",
        "audit": "node scripts/gigabrainctl.js audit --mode shadow",
        "passport": "node scripts/gigabrainctl.js passport",
        "inventory": "node scripts/gigabrainctl.js inventory",
        "doctor": "node scripts/gigabrainctl.js doctor",
        "world": "node scripts/gigabrainctl.js world rebuild",
        "orchestrator": "node scripts/gigabrainctl.js orchestrator explain",
        "synthesis": "node scripts/gigabrainctl.js synthesis build",
        "briefing": "node scripts/gigabrainctl.js briefing",
        "review": "node scripts/gigabrainctl.js review contradictions",
        "vault": "node scripts/gigabrainctl.js vault build",
        "vault:doctor": "node scripts/gigabrainctl.js vault doctor",
        "vault:report": "node scripts/gigabrainctl.js vault report",
        "vault:pull": "node scripts/gigabrainctl.js vault pull",
        "migrate:v3": "node scripts/migrate-v3.js",
        "harmonize": "node scripts/harmonize-memory.js",
        "vault:export": "node scripts/vault-export.js"
    },
    "keywords": [
        "openclaw",
        "memory",
        "cross-agent",
        "memory-bus",
        "memory-passport",
        "local-first",
        "plugin",
        "gigabrain",
        "codex",
        "claude",
        "mcp"
    ],
    "bin": {
        "gigabrainctl": "scripts/gigabrainctl.js",
        "gigabrain-codex-checkpoint": "scripts/gigabrain-codex-checkpoint.js",
        "gigabrain-mcp": "scripts/gigabrain-mcp.js",
        "gigabrain-codex-setup": "scripts/gigabrain-codex-setup.js",
        "gigabrain-hermes-setup": "scripts/gigabrain-hermes-setup.js",
        "gigabrain-claude-setup": "scripts/gigabrain-claude-setup.js"
    },
    "openclaw": {
        "extensions": [
            "./index.ts"
        ]
    },
    "peerDependencies": {
        "openclaw": ">=2026.2.15"
    },
    "peerDependenciesMeta": {
        "openclaw": {
            "optional": true
        }
    },
    "files": [
        "index.ts",
        "lib/",
        "scripts/",
        "docs/",
        "site/",
        "eval/*.js",
        "eval/deep-recall-summary-2026-03-11.md",
        "eval/cases.jsonl",
        "package.json",
        "CHANGELOG.md",
        "release-notes/",
        "openclaw.plugin.json",
        "README.md"
    ],
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "zod": "^4.4.3"
    }
}
